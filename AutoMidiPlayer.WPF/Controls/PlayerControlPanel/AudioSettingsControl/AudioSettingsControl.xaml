<UserControl x:Class="AutoMidiPlayer.WPF.Controls.PlayerControlPanel.AudioSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:s="https://github.com/canton7/Stylet"
             xmlns:controls="clr-namespace:AutoMidiPlayer.WPF.Controls"
             xmlns:button="clr-namespace:AutoMidiPlayer.WPF.Controls.SelectorPopupButton.Button"
             xmlns:services="clr-namespace:AutoMidiPlayer.WPF.Services"
             xmlns:entities="clr-namespace:AutoMidiPlayer.Data.Entities;assembly=AutoMidiPlayer.Data">
    <UserControl.Resources>
        <DataTemplate x:Key="SelectorDisplayItemTemplate">
            <TextBlock x:Name="DisplayText"
                       Text="{Binding Display}"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                             Value="True">
                    <Setter TargetName="DisplayText"
                            Property="FontWeight"
                            Value="SemiBold"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="SelectorKeyItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"
                                      SharedSizeGroup="SelectorKeyOffsetColumn"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="KeyOffsetText"
                           Grid.Column="0"
                           Text="{Binding OffsetDisplay}"
                           TextAlignment="Right"
                           HorizontalAlignment="Stretch"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                <TextBlock x:Name="KeyNoteText"
                           Grid.Column="1"
                           Margin="6,0,0,0"
                           Text="{Binding NoteDisplay}"
                           TextAlignment="Left"
                           HorizontalAlignment="Left"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                             Value="True">
                    <Setter TargetName="KeyOffsetText"
                            Property="FontWeight"
                            Value="SemiBold"/>
                    <Setter TargetName="KeyNoteText"
                            Property="FontWeight"
                            Value="SemiBold"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="SelectorTransposeItemTemplate">
            <TextBlock x:Name="TransposeText"
                       Text="{Binding Value}"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                             Value="True">
                    <Setter TargetName="TransposeText"
                            Property="FontWeight"
                            Value="SemiBold"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="12,0,0,0"
          VerticalAlignment="Center"
          HorizontalAlignment="Stretch"
          IsEnabled="{Binding PlaybackControls.HasSongOpen}"
          ClipToBounds="False">
        <controls:SimpleStackPanel Orientation="Horizontal"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Spacing="8">

            <!-- Key -->
            <Grid ClipToBounds="False">
                <button:PlayerControlDropdown ToolTip="Key offset for transposition"
                                              ItemsSource="{Binding SongSettings.KeyOptions}"
                                              SelectedItem="{Binding SongSettings.SelectedKeyOption, Mode=TwoWay}"
                                              ItemTemplate="{StaticResource SelectorKeyItemTemplate}"
                                              PopupMaxWidth="220">
                    <button:PlayerControlDropdown.ButtonContent>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding SongSettings.KeyDisplayText}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="42"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:SymbolIcon Symbol="MusicNote120"
                                           Filled="True"
                                           FontSize="14"
                                           Margin="0,0,4,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </button:PlayerControlDropdown.ButtonContent>
                </button:PlayerControlDropdown>

                <!-- Auto-correction indicator: floats below dropdown without affecting layout -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,3,-12"
                            ToolTip="{Binding SongSettings.AutoCorrectTooltip}"
                            Visibility="{Binding SongSettings.IsAutoCorrectActive, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                    <TextBlock Text="{Binding SongSettings.AutoCorrectEffectiveNote}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                    <ui:SymbolIcon Symbol="Checkmark12"
                                   FontSize="10"
                                   Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="1,1,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Speed -->
            <button:PlayerControlDropdown ToolTip="Playback speed"
                                          ItemsSource="{Binding SongSettings.SpeedOptions}"
                                          SelectedItem="{Binding SongSettings.SelectedSpeedOption, Mode=TwoWay}"
                                          IsActive="{Binding SongSettings.IsSpeedActive}"
                                          ItemTemplate="{StaticResource SelectorDisplayItemTemplate}"
                                          PopupMaxWidth="190">
                <button:PlayerControlDropdown.ButtonContent>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="42"
                                   Text="{Binding SongSettings.SpeedDisplayText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SongSettings.IsDefaultSpeed}"
                                                     Value="False">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ui:SymbolIcon Symbol="TopSpeed24"
                                       FontSize="14"
                                       Margin="4,0,0,0">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SongSettings.IsDefaultSpeed}"
                                                     Value="False">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </StackPanel>
                </button:PlayerControlDropdown.ButtonContent>
            </button:PlayerControlDropdown>

            <!-- Transpose Mode -->
            <button:PlayerControlDropdown ToolTip="Transpose mode for out-of-range notes"
                                          ItemsSource="{x:Static services:SongService.TransposeNames}"
                                          SelectedItem="{Binding SongSettings.Transpose, Mode=TwoWay}"
                                          IsActive="{Binding SongSettings.IsTransposeActive}"
                                          ItemTemplate="{StaticResource SelectorTransposeItemTemplate}"
                                          PopupMaxWidth="190">
                <button:PlayerControlDropdown.ButtonContent>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="52"
                                   Text="{Binding SongSettings.TransposeDisplayText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SongSettings.TransposeMode}"
                                                     Value="{x:Static entities:Transpose.Up}">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SongSettings.TransposeMode}"
                                                     Value="{x:Static entities:Transpose.Down}">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SongSettings.TransposeMode}"
                                                     Value="{x:Static entities:Transpose.Smart}">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Path Width="16"
                              Height="16"
                              Margin="4,0,0,0">
                            <Path.Style>
                                <Style TargetType="Path"
                                       BasedOn="{StaticResource PlayerControlIcon}">
                                    <Setter Property="Data"
                                            Value="{StaticResource TransposeIgnoreIconGeometry}"/>
                                    <Setter Property="Fill"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SongSettings.TransposeMode}"
                                                     Value="{x:Static entities:Transpose.Up}">
                                            <Setter Property="Data"
                                                    Value="{StaticResource TransposeUpIconGeometry}"/>
                                            <Setter Property="Fill"
                                                    Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SongSettings.TransposeMode}"
                                                     Value="{x:Static entities:Transpose.Down}">
                                            <Setter Property="Data"
                                                    Value="{StaticResource TransposeDownIconGeometry}"/>
                                            <Setter Property="Fill"
                                                    Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SongSettings.TransposeMode}"
                                                     Value="{x:Static entities:Transpose.Smart}">
                                            <Setter Property="Data"
                                                    Value="{StaticResource TransposeSmartIconGeometry}"/>
                                            <Setter Property="Fill"
                                                    Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </StackPanel>
                </button:PlayerControlDropdown.ButtonContent>
            </button:PlayerControlDropdown>
        </controls:SimpleStackPanel>
    </Grid>
</UserControl>
