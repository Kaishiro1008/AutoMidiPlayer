<UserControl x:Class="AutoMidiPlayer.WPF.Controls.SelectorPopupButton.Menu.SelectorMenuPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:AutoMidiPlayer.WPF.Helpers"
             x:Name="Root"
             Focusable="False">
        <Popup x:Name="SelectorPopup"
               PlacementTarget="{Binding PlacementTarget, ElementName=Root}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               Opened="SelectorPopup_Opened"
               Closed="SelectorPopup_Closed"
               IsOpen="{Binding IsOpen, ElementName=Root, Mode=TwoWay}">
                <Border x:Name="PopupSurface"
                        Margin="0"
                        CornerRadius="12"
                        ClipToBounds="True"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        PreviewMouseWheel="PopupBorder_PreviewMouseWheel">
                        <Border Padding="8"
                                MinWidth="{Binding PlacementTarget.ActualWidth, ElementName=Root}"
                                MaxWidth="{Binding MaxPopupWidth, ElementName=Root}"
                                HorizontalAlignment="Left"
                                CornerRadius="12"
                                ClipToBounds="True"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                <ListBox x:Name="SelectorListBox"
                                         Padding="0"
                                         Grid.IsSharedSizeScope="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MaxHeight="{Binding MaxPopupHeight, ElementName=Root}"
                                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="False"
                                         VirtualizingPanel.IsVirtualizing="False"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         helpers:ScrollEdgeFadeBehavior.IsEnabled="True"
                                         ItemsSource="{Binding ItemsSource, ElementName=Root}"
                                         DisplayMemberPath="{Binding DisplayMemberPath, ElementName=Root}"
                                         SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         SelectedIndex="{Binding SelectedIndex, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ItemTemplate="{Binding ItemTemplate, ElementName=Root}"
                                         SelectionChanged="SelectorListBox_SelectionChanged">
                                        <ListBox.Resources>
                                                <Style TargetType="ScrollViewer"
                                                       BasedOn="{StaticResource {x:Type ScrollViewer}}">
                                                        <Setter Property="Padding"
                                                                Value="0"/>
                                                </Style>
                                        </ListBox.Resources>
                                        <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                        <Setter Property="OverridesDefaultStyle"
                                                                Value="True"/>
                                                        <Setter Property="HorizontalContentAlignment"
                                                                Value="Stretch"/>
                                                        <Setter Property="Padding"
                                                                Value="8,6"/>
                                                        <Setter Property="Margin"
                                                                Value="0,1,4,1"/>
                                                        <Setter Property="Background"
                                                                Value="Transparent"/>
                                                        <Setter Property="BorderBrush"
                                                                Value="Transparent"/>
                                                        <Setter Property="BorderThickness"
                                                                Value="1"/>
                                                        <Setter Property="FocusVisualStyle"
                                                                Value="{x:Null}"/>
                                                        <Setter Property="Template">
                                                                <Setter.Value>
                                                                        <ControlTemplate TargetType="ListBoxItem">
                                                                                <Border x:Name="ItemBorder"
                                                                                        CornerRadius="8"
                                                                                        Padding="{TemplateBinding Padding}"
                                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                                        Background="{TemplateBinding Background}">
                                                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver"
                                                                                                 Value="True">
                                                                                                <Setter TargetName="ItemBorder"
                                                                                                        Property="Background"
                                                                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                                                        </Trigger>
                                                                                        <Trigger Property="IsSelected"
                                                                                                 Value="True">
                                                                                                <Setter TargetName="ItemBorder"
                                                                                                        Property="BorderBrush"
                                                                                                        Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                                                                                <Setter TargetName="ItemBorder"
                                                                                                        Property="Background"
                                                                                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                                                                        </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                </Setter.Value>
                                                        </Setter>
                                                </Style>
                                        </ListBox.ItemContainerStyle>
                                </ListBox>
                        </Border>
                </Border>
        </Popup>
</UserControl>
