<ui:ContentDialog x:Class="AutoMidiPlayer.WPF.Dialogs.ThirdPartyLicenseDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:helpers="clr-namespace:AutoMidiPlayer.WPF.Helpers"
                  IsFooterVisible="False"
                  CloseButtonText="{x:Null}"
                  PrimaryButtonText="{x:Null}"
                  SecondaryButtonText="{x:Null}"
                  Padding="24,24,12,24"
                  helpers:ScrollEdgeFadeBehavior.IsEnabled="True"
                  helpers:ScrollEdgeFadeBehavior.FadeRampDistance="110"
                  helpers:ScrollEdgeFadeBehavior.EdgeFadeThickness="0.18"
                  helpers:ScrollEdgeFadeBehavior.MaxFadeOpacity="0.92">

    <ui:ContentDialog.Title>
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="{Binding DialogSubtitle}" FontSize="12" Opacity="0.7" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6"
                    Margin="16,0,0,0"
                    VerticalAlignment="Top"
                    Click="CloseButton_Click"
                    Cursor="Hand"
                    ToolTip="Close"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                <ui:SymbolIcon Symbol="Dismiss24" FontSize="16"/>
            </Button>
        </Grid>
    </ui:ContentDialog.Title>

    <StackPanel Background="Transparent"
                Margin="0,0,12,0"
                TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <TextBlock Text="{Binding LicenseText}"
                   TextWrapping="Wrap"
                   FontFamily="Consolas"
                   FontSize="11"/>
    </StackPanel>
</ui:ContentDialog>
