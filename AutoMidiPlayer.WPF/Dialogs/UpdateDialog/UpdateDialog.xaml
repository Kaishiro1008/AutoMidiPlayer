<ui:ContentDialog x:Class="AutoMidiPlayer.WPF.Dialogs.UpdateDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:s="https://github.com/canton7/Stylet"
                  xmlns:button="clr-namespace:AutoMidiPlayer.WPF.Controls.SelectorPopupButton.Button"
                  PrimaryButtonText="Update"
                  CloseButtonText="Cancel"
                  DefaultButton="Primary">

    <ui:ContentDialog.Title>
        <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,8,0" FontSize="20"/>
            <TextBlock Text="Update Available" VerticalAlignment="Center"/>
        </StackPanel>
    </ui:ContentDialog.Title>

    <ui:ContentDialog.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:ContentDialog.Resources>
    
    <StackPanel Background="Transparent" Margin="0" Width="420">
        <WrapPanel Margin="0,0,0,8">
            <StackPanel Margin="0,0,24,12" Width="180">
                <TextBlock Text="Version Type" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <button:StandardDropdown ItemsSource="{Binding VersionTypes}" 
                                         SelectedItem="{Binding SelectedVersionType}" 
                                         HorizontalAlignment="Stretch"
                                         IsEnabled="{Binding IsNotUpdating, FallbackValue=True}"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,12" Width="180">
                <TextBlock Text="Clear App Data" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <ui:ToggleSwitch IsChecked="{Binding ClearAppData}" 
                                 HorizontalAlignment="Left"
                                 Margin="0,4,0,0" 
                                 IsEnabled="{Binding IsNotUpdating, FallbackValue=True}"/>
            </StackPanel>
        </WrapPanel>
                         
        <TextBlock Text="{Binding UpdateMessage}" 
                   Opacity="0.6"
                   FontSize="12"
                   Margin="0,0,0,16"
                   MaxWidth="640" TextWrapping="Wrap"/>

    </StackPanel>
</ui:ContentDialog>
