<ui:ContentDialog x:Class="AutoMidiPlayer.WPF.Dialogs.UpdateProgressDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  Title="Updating">

    <StackPanel Background="Transparent" Margin="0,0,12,0" Width="400">
        <TextBlock Text="{Binding ProgressText}" Margin="0,0,0,4"/>
        <ProgressBar IsIndeterminate="True" Height="4"/>
    </StackPanel>
</ui:ContentDialog>
