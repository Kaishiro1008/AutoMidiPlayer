<UserControl
    x:Class="AutoMidiPlayer.WPF.Views.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:controls="clr-namespace:AutoMidiPlayer.WPF.Controls"
    xmlns:helpers="clr-namespace:AutoMidiPlayer.WPF.Helpers"
    xmlns:viewModels="clr-namespace:AutoMidiPlayer.WPF.ViewModels"
    xmlns:properties="clr-namespace:AutoMidiPlayer.Data.Properties;assembly=AutoMidiPlayer.Data"
    d:DataContext="{d:DesignInstance Type=viewModels:AboutViewModel}">
    <UserControl.Resources>
        <properties:Settings x:Key="Settings"/>

        <Style x:Key="AnimatedCardButtonStyle"
               TargetType="Button">
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Background"
                    Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"/>
                            <Border x:Name="HoverBorder"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Opacity="0"/>
                            <Border x:Name="PressedBorder"
                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.24">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressedBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.09">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PressedBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.24">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AboutActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AnimatedCardButtonStyle}">
            <Setter Property="Padding"
                    Value="12,6"/>
            <Setter Property="Margin"
                    Value="0,0,12,12"/>
            <Setter Property="MinWidth"
                    Value="180"/>
            <Setter Property="HorizontalAlignment"
                    Value="Left"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
        </Style>

        <Style x:Key="LicenseChipButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AnimatedCardButtonStyle}">
            <Setter Property="Padding"
                    Value="16,12"/>
            <Setter Property="Margin"
                    Value="0,0,12,12"/>
            <Setter Property="MinWidth"
                    Value="220"/>
            <Setter Property="HorizontalAlignment"
                    Value="Left"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer helpers:ScrollEdgeFadeBehavior.IsEnabled="True">
        <controls:SimpleStackPanel Spacing="16">
            <StackPanel HorizontalAlignment="Center"
                        Margin="0,32,0,16">
                <Image Width="64"
                       Height="64"
                       Source="pack://application:,,,/Resources/logo.png"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

                <TextBlock Text="{Binding AppName}"
                           FontWeight="Bold"
                           FontSize="24"
                           TextAlignment="Center"/>

                <TextBlock FontSize="12"
                           Opacity="0.6"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0">
                    <Run Text="Version "/>
                    <Run Text="{Binding VersionDisplay, Mode=OneTime}"/>
                </TextBlock>

                <TextBlock Text="A feature-rich MIDI-to-key player for in-game instruments, built with C# and WPF and styled with Windows Mica."
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           FontSize="12"
                           Opacity="0.8"
                           Margin="0,16,0,0"/>

                <TextBlock FontSize="12"
                           Opacity="0.7"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0">
                    <Run Text="If you like the app, consider "/>
                    <InlineUIContainer BaselineAlignment="Center">
                        <controls:Hyperlink NavigateUri="https://github.com/Jed556/AutoMidiPlayer/blob/main/CONTRIBUTING.md">
                            <TextBlock Text="contributing"
                                       FontSize="12"/>
                        </controls:Hyperlink>
                    </InlineUIContainer>
                    <Run Text=" or giving a 🌟 star on "/>
                    <InlineUIContainer BaselineAlignment="Center">
                        <controls:Hyperlink NavigateUri="https://github.com/Jed556/AutoMidiPlayer">
                            <TextBlock Text="GitHub"
                                       FontSize="12"/>
                        </controls:Hyperlink>
                    </InlineUIContainer>
                    <Run Text=". Thank you~"/>
                </TextBlock>
            </StackPanel>

            <controls:Section Title="Links">
                <controls:SimpleStackPanel Spacing="8">
                    <ItemsControl ItemsSource="{Binding Links}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource AboutActionButtonStyle}"
                                        Command="{s:Action OpenUrl}"
                                        CommandParameter="{Binding Url}">
                                    <Button.ToolTip>
                                        <TextBlock Text="{Binding Tooltip}"
                                                   FontSize="10"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="380"/>
                                    </Button.ToolTip>
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:SimpleStackPanel>
            </controls:Section>

            <controls:Section Title="Special Thanks">
                <controls:SimpleStackPanel Spacing="8">
                    <TextBlock TextWrapping="Wrap"
                               FontSize="12">
                        This project was originally forked from <InlineUIContainer BaselineAlignment="Center"><controls:Hyperlink NavigateUri="https://github.com/sabihoshi/GenshinLyreMidiPlayer"><TextBlock Text="sabihoshi/GenshinLyreMidiPlayer"
                                                                                                                                                                                                              FontSize="12"/></controls:Hyperlink></InlineUIContainer> v4.0.5 and later detached into its own repository to enable multi-game support and features that do not fit the original Genshin Impact-only design. Huge thanks for the original work!
                    </TextBlock>

                    <TextBlock Text="Contributors"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0"/>

                    <ItemsControl ItemsSource="{Binding Contributors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{s:Action OpenUrl}"
                                        CommandParameter="{Binding ProfileUrl}"
                                        Padding="0"
                                        Margin="0,0,8,8"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Border CornerRadius="20"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            Padding="4">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="32"
                                                    Height="32"
                                                    CornerRadius="16"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <Grid>
                                                    <ui:SymbolIcon Symbol="Person24"
                                                                   FontSize="16"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <Image Source="{Binding AvatarPath, TargetNullValue={x:Null}}"
                                                           Stretch="UniformToFill">
                                                        <Image.Clip>
                                                            <EllipseGeometry RadiusX="16"
                                                                             RadiusY="16"
                                                                             Center="16,16"/>
                                                        </Image.Clip>
                                                    </Image>
                                                </Grid>
                                            </Border>
                                            <Grid>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="MaxWidth"
                                                                Value="0"/>
                                                        <Setter Property="Opacity"
                                                                Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                         Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="MaxWidth"
                                                                                             To="120"
                                                                                             Duration="0:0:0.25">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <CubicEase EasingMode="EaseInOut"/>
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                             To="1"
                                                                                             Duration="0:0:0.25">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <CubicEase EasingMode="EaseInOut"/>
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="MaxWidth"
                                                                                             To="0"
                                                                                             Duration="0:0:0.25">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <CubicEase EasingMode="EaseInOut"/>
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                             To="0"
                                                                                             Duration="0:0:0.25">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <CubicEase EasingMode="EaseInOut"/>
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <TextBlock Text="{Binding Name}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,12,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:SimpleStackPanel>
            </controls:Section>

            <controls:Section Title="Open Source Licenses">
                <controls:SimpleStackPanel Spacing="6">

                    <ItemsControl ItemsSource="{Binding ThirdPartyLicenses}"
                                  Margin="0,6,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource LicenseChipButtonStyle}"
                                        Command="{s:Action ShowThirdPartyLicense}"
                                        CommandParameter="{Binding}">
                                    <controls:SimpleStackPanel Spacing="4">
                                        <WrapPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Version}"
                                                       FontSize="12"
                                                       Opacity="0.6"
                                                       VerticalAlignment="Center"/>
                                        </WrapPanel>
                                        <TextBlock Text="{Binding LicenseName}"
                                                   FontSize="12"
                                                   Opacity="0.7"/>
                                    </controls:SimpleStackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="11"
                               Opacity="0.7">
                        All rights reserved by © miHoYo Co., Ltd., © XD Inc., © thatgamecompany, Inc., © Roblox Corporation, and © Hotta Studio, a Perfect World company.
                        Not affiliated with miHoYo, XD, thatgamecompany, Roblox, or Hotta Studio.
                    </TextBlock>
                </controls:SimpleStackPanel>
            </controls:Section>
        </controls:SimpleStackPanel>
    </ScrollViewer>
</UserControl>
