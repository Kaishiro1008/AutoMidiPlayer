<UserControl
    x:Class="AutoMidiPlayer.WPF.Views.SettingsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:core="clr-namespace:AutoMidiPlayer.WPF.Core"
    xmlns:controls="clr-namespace:AutoMidiPlayer.WPF.Controls"
    xmlns:button="clr-namespace:AutoMidiPlayer.WPF.Controls.SelectorPopupButton.Button"
    xmlns:viewModels="clr-namespace:AutoMidiPlayer.WPF.ViewModels"
    xmlns:transitions="clr-namespace:AutoMidiPlayer.WPF.Animation.Transitions"
    xmlns:properties="clr-namespace:AutoMidiPlayer.Data.Properties;assembly=AutoMidiPlayer.Data"
    xmlns:games="clr-namespace:AutoMidiPlayer.WPF.Core.Games"
    xmlns:helpers="clr-namespace:AutoMidiPlayer.WPF.Helpers"
    d:DataContext="{d:DesignInstance Type=viewModels:SettingsPageViewModel}">
    <UserControl.Resources>
        <properties:Settings x:Key="Settings"/>
        <helpers:BindingProxy x:Key="SettingsVmProxy"
                              Data="{Binding}"/>
        <DataTemplate x:Key="OffsetNoteTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding OffsetDisplay}"
                           MinWidth="24"
                           TextAlignment="Right"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="{Binding NoteDisplay}"
                           Margin="6,0,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
        </DataTemplate>
        <Style x:Key="DebugSectionContentContainerStyle"
               TargetType="Border">
            <Setter Property="Opacity"
                    Value="0"/>
            <Setter Property="MaxHeight"
                    Value="0"/>
            <Setter Property="IsHitTestVisible"
                    Value="False"/>
            <Setter Property="ClipToBounds"
                    Value="True"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="-8"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DebugModeEnabled}"
                             Value="True">
                    <Setter Property="IsHitTestVisible"
                            Value="True"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                 To="360"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                 To="0"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-8"
                                                 Duration="0:0:0.18">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="RootScrollViewer"
                  helpers:ScrollEdgeFadeBehavior.IsEnabled="True">
        <controls:SimpleStackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <controls:SimpleStackPanel Grid.Column="0"
                                           Margin="0,0,10,0">

                    <!-- Player Section -->
                    <controls:Section Title="Player">
                        <controls:SimpleStackPanel>
                            <ui:ToggleSwitch
                                Content="Auto Enable Listen Mode"
                                IsChecked="{Binding AutoEnableListenMode}"
                                ToolTip="Playing a song will automatically switch to Listen Mode (Speakers) if the selected game isn't running."/>

                            <GroupBox Header="Keypress Method"
                                      Margin="0,8,0,0">
                                <button:StandardDropdown
                                    SelectedItem="{Binding SelectedKeypressInputMode}"
                                    ItemsSource="{x:Static viewModels:SettingsPageViewModel.KeypressInputModes}"
                                    DisplayMemberPath="Name"
                                    HorizontalAlignment="Left"
                                    MinWidth="220"/>
                            </GroupBox>

                            <TextBlock Text="{Binding KeypressInputDescription}"
                                       TextWrapping="Wrap"
                                       Opacity="0.6"
                                       FontSize="12"
                                       Margin="0,-8,0,0"/>

                            <WrapPanel Margin="0,8,0,0">
                                <ui:ToggleSwitch
                                    Content="Enable Key-up"
                                    IsChecked="{Binding EnableKeyUp}"
                                    Margin="0,0,32,8"
                                    ToolTip="When enabled, key-up is sent after key-down for press actions across all keypress methods."/>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,8">
                                    <TextBlock Text="Delay (ms)"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <controls:Numberbox
                                        Value="{Binding KeyboardPressDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="0"
                                        Maximum="1000"
                                        MaxDecimalPlaces="0"
                                        FixedWidth="True"
                                        ToolTip="Delay between key-down and key-up for press actions."/>
                                </StackPanel>
                            </WrapPanel>

                            <GroupBox Header="Auto Correct Threshold"
                                      Margin="0,8,0,0">
                                <controls:SimpleStackPanel>
                                    <controls:Slider
                                        CustomTicks="{x:Static viewModels:SettingsPageViewModel.AutoCorrectThresholdTicks}"
                                        MinimumTickGap="12"
                                        IsSnapToTickEnabled="True"
                                        TickPlacement="BottomRight"
                                        Value="{Binding AutoCorrectThresholdValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ThumbToolTipOptions="{Binding AutoCorrectThresholdToolTipOptions}"/>
                                    <TextBlock Text="{Binding AutoCorrectThresholdDescription}"
                                               TextWrapping="Wrap"
                                               Opacity="0.6"
                                               FontSize="12"
                                               Margin="0,-4,0,0"/>
                                </controls:SimpleStackPanel>
                            </GroupBox>
                        </controls:SimpleStackPanel>
                    </controls:Section>

                    <!-- Hotkeys Section -->
                    <controls:Section Title="Hotkeys"
                                      Margin="0,16,0,0">
                        <controls:Section.HeaderContent>
                            <Button Style="{DynamicResource IconButton}"
                                    Command="{s:Action ResetHotkeys}"
                                    ToolTip="Reset all hotkeys to defaults"
                                    Visibility="{Binding HotkeysEnabled, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"
                                    Margin="0,0,0,2">
                                <ui:SymbolIcon Symbol="ArrowClockwise24"
                                               FontSize="18"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Button>
                        </controls:Section.HeaderContent>
                        <controls:SimpleStackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:ToggleSwitch Grid.Column="0"
                                                 Content="Enable hotkeys"
                                                 IsChecked="{Binding HotkeysEnabled}"
                                                 ToolTip="When enabled, hotkeys work even when the app is not focused"/>
                            </Grid>

                            <TextBlock Text="Hotkeys work even when the app is not in focus. Requires at least one modifier key (Ctrl, Alt, Shift)."
                                       TextWrapping="Wrap"
                                       Opacity="0.6"
                                       FontSize="12"
                                       Margin="0,0,0,0"/>

                            <WrapPanel Visibility="{Binding HotkeysEnabled, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                <TextBlock Text="Stop Playback on Mouse Click"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,8"/>
                                <button:StandardDropdown
                                    SelectedItem="{Binding SelectedMouseStopClickOption}"
                                    ItemsSource="{x:Static viewModels:SettingsPageViewModel.MouseStopClickOptions}"
                                    DisplayMemberPath="Name"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,8"/>
                            </WrapPanel>

                            <controls:SimpleStackPanel Spacing="8"
                                                       Grid.IsSharedSizeScope="True"
                                                       Visibility="{Binding HotkeysEnabled, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                <controls:HotkeyEditControl
                                    HotkeyBinding="{Binding PlayPauseHotkey}"
                                    HotkeyChanged="OnHotkeyChanged"
                                    HotkeyCleared="OnHotkeyCleared"
                                    EditStarted="OnHotkeyEditStarted"
                                    EditEnded="OnHotkeyEditEnded"/>
                                <controls:HotkeyEditControl
                                    HotkeyBinding="{Binding NextHotkey}"
                                    HotkeyChanged="OnHotkeyChanged"
                                    HotkeyCleared="OnHotkeyCleared"
                                    EditStarted="OnHotkeyEditStarted"
                                    EditEnded="OnHotkeyEditEnded"/>
                                <controls:HotkeyEditControl
                                    HotkeyBinding="{Binding PreviousHotkey}"
                                    HotkeyChanged="OnHotkeyChanged"
                                    HotkeyCleared="OnHotkeyCleared"
                                    EditStarted="OnHotkeyEditStarted"
                                    EditEnded="OnHotkeyEditEnded"/>
                                <controls:HotkeyEditControl
                                    HotkeyBinding="{Binding SpeedUpHotkey}"
                                    HotkeyChanged="OnHotkeyChanged"
                                    HotkeyCleared="OnHotkeyCleared"
                                    EditStarted="OnHotkeyEditStarted"
                                    EditEnded="OnHotkeyEditEnded"/>
                                <controls:HotkeyEditControl
                                    HotkeyBinding="{Binding SpeedDownHotkey}"
                                    HotkeyChanged="OnHotkeyChanged"
                                    HotkeyCleared="OnHotkeyCleared"
                                    EditStarted="OnHotkeyEditStarted"
                                    EditEnded="OnHotkeyEditEnded"/>
                                <controls:HotkeyEditControl
                                    HotkeyBinding="{Binding PanicHotkey}"
                                    HotkeyChanged="OnHotkeyChanged"
                                    HotkeyCleared="OnHotkeyCleared"
                                    EditStarted="OnHotkeyEditStarted"
                                    EditEnded="OnHotkeyEditEnded"/>
                            </controls:SimpleStackPanel>
                        </controls:SimpleStackPanel>
                    </controls:Section>

                    <!-- Locations Section -->
                    <controls:Section Title="Locations"
                                      Margin="0,16,0,0">
                        <controls:SimpleStackPanel>
                            <GroupBox Padding="0">
                                <GroupBox.Header>
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Game Locations"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                        <controls:RotateToggleButton Grid.Column="1"
                                                                     s:View.ActionTarget="{Binding Data, Source={StaticResource SettingsVmProxy}}"
                                                                     IsRotated="{Binding IsGameLocationsExpanded}"
                                                                     Command="{s:Action ToggleGameLocationsExpanded}"
                                                                     ButtonToolTip="Expand Game Locations"/>
                                    </Grid>
                                </GroupBox.Header>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity"
                                                    Value="0"/>
                                            <Setter Property="MaxHeight"
                                                    Value="0"/>
                                            <Setter Property="IsHitTestVisible"
                                                    Value="False"/>
                                            <Setter Property="ClipToBounds"
                                                    Value="True"/>
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform Y="-8"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGameLocationsExpanded}"
                                                             Value="True">
                                                    <Setter Property="IsHitTestVisible"
                                                            Value="True"/>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 To="1"
                                                                                 Duration="0:0:0.22">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                                 To="1500"
                                                                                 Duration="0:0:0.22">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                 To="0"
                                                                                 Duration="0:0:0.22">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 To="0"
                                                                                 Duration="0:0:0.18">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseIn"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                                 To="0"
                                                                                 Duration="0:0:0.18">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseIn"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                 To="-8"
                                                                                 Duration="0:0:0.18">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseIn"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <controls:SimpleStackPanel Margin="0,12,0,0"
                                                               Spacing="8">
                                        <TextBlock Text="Running games are auto-detected. Set a location only to target a specific .exe file."
                                                   TextWrapping="Wrap"
                                                   Opacity="0.6"
                                                   FontSize="12"/>
                                        <ItemsControl ItemsSource="{Binding GameLocations}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type games:GameInfo}">
                                                    <GroupBox Margin="0,0,0,4">
                                                        <GroupBox.Header>
                                                            <TextBlock>
                                                            <Run Text="{Binding DisplayName, Mode=OneWay}"/><Run Text=" Location"/>
                                                            </TextBlock>
                                                        </GroupBox.Header>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Button Style="{DynamicResource IconButton}"
                                                                    s:View.ActionTarget="{Binding Data, Source={StaticResource SettingsVmProxy}}"
                                                                    CommandParameter="{Binding}"
                                                                    Command="{s:Action BrowseGameLocation}"
                                                                    Width="28"
                                                                    Height="28"
                                                                    MinWidth="0"
                                                                    Padding="0">
                                                                <ui:SymbolIcon Symbol="AppsAddIn16"
                                                                               FontSize="16"/>
                                                            </Button>
                                                            <TextBlock Grid.Column="1"
                                                                       Margin="4,0,0,0"
                                                                       Text="{Binding Location}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Location}"/>
                                                        </Grid>
                                                    </GroupBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </controls:SimpleStackPanel>
                                </Border>
                            </GroupBox>

                            <GroupBox Header="MIDI Folder">
                                <controls:SimpleStackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Style="{DynamicResource IconButton}"
                                                Command="{s:Action BrowseMidiFolder}"
                                                Width="28"
                                                Height="28"
                                                MinWidth="0"
                                                Padding="0"
                                                ToolTip="Browse for MIDI folder"
                                                Visibility="{Binding HasMidiFolder, Converter={x:Static s:BoolToVisibilityConverter.InverseInstance}}">
                                            <ui:SymbolIcon Symbol="FolderAdd16"
                                                           FontSize="16"/>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Style="{DynamicResource IconButton}"
                                                Command="{s:Action OpenMidiFolder}"
                                                Width="28"
                                                Height="28"
                                                MinWidth="0"
                                                Padding="0"
                                                ToolTip="Open MIDI folder in Explorer"
                                                Visibility="{Binding HasAccessibleMidiFolder, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                            <ui:SymbolIcon Symbol="FolderOpen16"
                                                           FontSize="16"/>
                                        </Button>
                                        <Border Grid.Column="2"
                                                Padding="6"
                                                Background="Transparent"
                                                ToolTip="MIDI folder can&apos;t be found. Select a new folder path."
                                                Visibility="{Binding IsMidiFolderMissing, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                            <ui:SymbolIcon Symbol="ErrorCircle12"
                                                           Foreground="#C42B1C"
                                                           FontSize="18"/>
                                        </Border>
                                        <Button Grid.Column="3"
                                                Style="{DynamicResource IconButton}"
                                                Command="{s:Action ScanMidiFolder}"
                                                Width="28"
                                                Height="28"
                                                MinWidth="0"
                                                Padding="0"
                                                ToolTip="Refresh/Scan folder for new MIDI files"
                                                Visibility="{Binding ShowMidiFolderManualRefresh, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                            <ui:SymbolIcon Symbol="ArrowClockwise24"
                                                           FontSize="16"/>
                                        </Button>
                                        <Button Grid.Column="4"
                                                Style="{DynamicResource IconButton}"
                                                Command="{s:Action ClearMidiFolder}"
                                                Width="28"
                                                Height="28"
                                                MinWidth="0"
                                                Padding="0"
                                                ToolTip="Clear MIDI folder"
                                                Visibility="{Binding HasMidiFolder, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                            <ui:SymbolIcon Symbol="Delete16"
                                                           FontSize="16"/>
                                        </Button>
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding MidiFolder, TargetNullValue='No folder selected'}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="4,0,0,0"
                                                   ToolTip="{Binding MidiFolder, TargetNullValue='No folder selected'}"/>
                                    </Grid>

                                    <ui:ToggleSwitch Content="Auto-scan folder for new MIDI files"
                                                     IsChecked="{Binding AutoScanMidiFolder}"
                                                     Margin="0,8,0,0"
                                                     ToolTip="When enabled, Auto MIDI Player watches this folder and auto-imports newly added MIDI files."
                                                     Visibility="{Binding HasMidiFolder, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>
                                </controls:SimpleStackPanel>
                            </GroupBox>

                            <GroupBox Header="Data Location">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{DynamicResource IconButton}"
                                            Command="{s:Action OpenDataFolder}"
                                            Width="28"
                                            Height="28"
                                            MinWidth="0"
                                            Padding="0"
                                            ToolTip="Open data folder in Explorer">
                                        <ui:SymbolIcon Symbol="FolderOpen16"
                                                       FontSize="16"/>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Style="{DynamicResource IconButton}"
                                            Command="{s:Action ResetAppData}"
                                            Width="28"
                                            Height="28"
                                            MinWidth="0"
                                            Padding="0"
                                            ToolTip="Clear/reset app data">
                                        <ui:SymbolIcon Symbol="ArrowClockwise24"
                                                       FontSize="16"/>
                                    </Button>
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Static viewModels:SettingsPageViewModel.DataLocation}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4,0,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               ToolTip="{x:Static viewModels:SettingsPageViewModel.DataLocation}"/>
                                </Grid>
                            </GroupBox>
                        </controls:SimpleStackPanel>
                    </controls:Section>

                </controls:SimpleStackPanel>

                <!-- Right Column -->
                <controls:SimpleStackPanel Grid.Column="1"
                                           Margin="10,0,0,0">

                    <!-- New Song Defaults Section -->
                    <controls:Section Title="New Song Defaults"
                                      Description="Applied when importing new songs.">
                        <controls:Section.HeaderContent>
                            <Button Style="{DynamicResource IconButton}"
                                    Command="{s:Action ResetSongDefaults}"
                                    ToolTip="Reset song defaults"
                                    Margin="0,0,0,2">
                                <ui:SymbolIcon Symbol="ArrowClockwise24"
                                               FontSize="18"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Button>
                        </controls:Section.HeaderContent>

                        <WrapPanel>
                            <GroupBox Header="Key Defaults"
                                      Margin="0,0,16,8">
                                <controls:SimpleStackPanel>
                                    <WrapPanel Margin="0,0,0,0">
                                        <controls:SimpleStackPanel Spacing="4"
                                                                   Margin="0,0,24,8">
                                            <TextBlock Text="Base Key Offset"
                                                       FontWeight="SemiBold"/>
                                            <button:StandardDropdown SelectedItem="{Binding SelectedNewSongBaseKeyOption}"
                                                                     ItemsSource="{x:Static viewModels:SettingsPageViewModel.NewSongBaseKeyOptions}"
                                                                     ItemTemplate="{StaticResource OffsetNoteTemplate}"
                                                                     HorizontalAlignment="Left"/>
                                        </controls:SimpleStackPanel>

                                        <controls:SimpleStackPanel Spacing="4"
                                                                   Margin="0,0,0,8">
                                            <TextBlock Text="Key Offset"
                                                       FontWeight="SemiBold"/>
                                            <button:StandardDropdown SelectedItem="{Binding SelectedNewSongKeyOption}"
                                                                     ItemsSource="{Binding NewSongKeyOptions}"
                                                                     ItemTemplate="{StaticResource OffsetNoteTemplate}"
                                                                     HorizontalAlignment="Left"/>
                                        </controls:SimpleStackPanel>
                                    </WrapPanel>
                                    <ui:ToggleSwitch Content="Auto Detect Base Key"
                                                     IsChecked="{Binding AutoDetectBaseKey}"
                                                     Margin="0,0,0,0"
                                                     ToolTip="When enabled, newly imported songs try to auto-detect the song base key. If detection fails, the key defaults above are used."/>
                                </controls:SimpleStackPanel>
                            </GroupBox>

                            <WrapPanel Margin="0,0,16,0">
                                <GroupBox Header="Transpose"
                                          Margin="0,0,18,8">
                                    <button:StandardDropdown SelectedItem="{Binding SelectedNewSongTransposeOption}"
                                                             ItemsSource="{x:Static viewModels:SettingsPageViewModel.NewSongTransposeOptions}"
                                                             DisplayMemberPath="Value"
                                                             HorizontalAlignment="Left"/>
                                </GroupBox>

                                <GroupBox Header="Hold Notes"
                                          Margin="0,0,0,8">
                                    <ui:ToggleSwitch Content="Enable"
                                                     IsChecked="{Binding DefaultSongHoldNotes}"
                                                     Margin="0,4,0,0"/>
                                </GroupBox>
                            </WrapPanel>

                            <GroupBox Header="Merge Notes"
                                      Margin="0,0,16,8">
                                <WrapPanel>
                                    <controls:SimpleStackPanel Spacing="4"
                                                               Margin="0,0,24,8">
                                        <TextBlock Text="Enable"
                                                   FontWeight="SemiBold"/>
                                        <Border Height="32">
                                            <ui:ToggleSwitch IsChecked="{Binding DefaultSongMergeNotes}"
                                                             VerticalAlignment="Center"/>
                                        </Border>
                                    </controls:SimpleStackPanel>
                                    <controls:SimpleStackPanel Spacing="4"
                                                               Margin="0,0,0,8">
                                        <TextBlock Text="Tolerance (ms)"
                                                   FontWeight="SemiBold"/>
                                        <controls:Numberbox Value="{Binding DefaultSongMergeMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Minimum="1"
                                                            Maximum="1000"
                                                            MaxDecimalPlaces="0"
                                                            FixedWidth="True"
                                                            IsEnabled="{Binding CanEditDefaultSongMergeMilliseconds}"/>
                                    </controls:SimpleStackPanel>
                                </WrapPanel>
                            </GroupBox>
                        </WrapPanel>
                    </controls:Section>

                    <!-- Version Section -->
                    <controls:Section x:Name="VersionSection"
                                      Title="Version"
                                      Margin="0,16,0,0">
                        <controls:Section.HeaderContent>
                            <Border Visibility="{Binding NeedsUpdate, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"
                                    Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                    CornerRadius="10"
                                    Margin="0,4,0,0"
                                    Padding="8,2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="New Update"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ApplicationBackgroundBrush}"/>
                            </Border>
                        </controls:Section.HeaderContent>

                        <controls:SimpleStackPanel>
                            <controls:SimpleStackPanel Orientation="Horizontal"
                                                       Spacing="8">
                                <TextBlock VerticalAlignment="Center">
                                v<Run Text="{Binding ProgramVersionDisplay, Mode=OneTime}"/>
                                </TextBlock>
                                <ui:SymbolIcon Symbol="TriangleRight20"
                                               FontSize="8"
                                               Filled="True"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding NeedsUpdate, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>
                                <TextBlock VerticalAlignment="Center"
                                           Visibility="{Binding NeedsUpdate, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                    <Run Text="{Binding LatestVersion.TagName}"/>
                                </TextBlock>
                                <controls:Hyperlink NavigateUri="{Binding LatestVersion.Url, TargetNullValue={x:Null}}"
                                                    Padding="2"
                                                    NormalOpacity="0.42"
                                                    PointerOverOpacity="1"
                                                    PreviewToolTip="{Binding LatestVersion.Url, StringFormat=Open update page: {0}}"
                                                    Visibility="{Binding NeedsUpdate, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                    <ui:SymbolIcon Symbol="ArrowCircleUp12"
                                                   FontSize="16"
                                                   Filled="True"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=controls:Hyperlink}}"/>
                                </controls:Hyperlink>
                                <controls:BusyActionButton Width="24"
                                                           Height="24"
                                                           IsBusy="{Binding IsCheckingUpdate}"
                                                           MinimumVisibleDuration="0:0:1"
                                                           Command="{s:Action CheckForUpdate}"
                                                           ButtonPadding="2"
                                                           ButtonToolTip="Check for updates"
                                                           IconSymbol="ArrowClockwise24"
                                                           IconFontSize="16"
                                                           IndicatorSize="16"/>
                            </controls:SimpleStackPanel>

                            <WrapPanel>
                                <ui:ToggleSwitch Content="Auto-check updates"
                                                 IsChecked="{Binding AutoCheckUpdates}"
                                                 Margin="0,0,16,8"/>
                                <ui:ToggleSwitch Content="Include beta updates"
                                                 IsChecked="{Binding IncludeBetaUpdates}"
                                                 Margin="0,0,16,8"/>
                            </WrapPanel>
                        </controls:SimpleStackPanel>
                    </controls:Section>

                    <!-- Style Section -->
                    <controls:Section Title="Style"
                                      Margin="0,16,0,0">
                        <WrapPanel>
                            <GroupBox Header="Theme Mode"
                                      Margin="0,0,16,8">
                                <button:StandardDropdown
                                    SelectedItem="{Binding SelectedTheme}"
                                    ItemsSource="{x:Static viewModels:SettingsPageViewModel.ThemeOptions}"
                                    DisplayMemberPath="Name"
                                    HorizontalAlignment="Left"/>
                            </GroupBox>
                            <GroupBox Header="Accent Color"
                                      Margin="0,0,16,8">
                                <button:StandardDropdown
                                    SelectedItem="{Binding SelectedAccentColor}"
                                    ItemsSource="{x:Static viewModels:SettingsPageViewModel.AccentColors}"
                                    HorizontalAlignment="Left">
                                    <button:StandardDropdown.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="16"
                                                        Height="16"
                                                        CornerRadius="8"
                                                        Background="{Binding ColorBrush}"
                                                        Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Name}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </button:StandardDropdown.ItemTemplate>
                                </button:StandardDropdown>
                            </GroupBox>

                            <GroupBox Header="Transition Style"
                                      Margin="0,0,16,8">
                                <button:StandardDropdown
                                    SelectedItem="{Binding Transition}"
                                    SelectedIndex="{Binding Default.SelectedTransition, Source={StaticResource Settings}}"
                                    ItemsSource="{x:Static transitions:TransitionCollection.Transitions}"
                                    HorizontalAlignment="Left"/>
                            </GroupBox>
                            <GroupBox Header="Smooth Scrolling"
                                      Margin="0,0,16,8">
                                <ui:ToggleSwitch Content="Enable"
                                                 IsChecked="{Binding SmoothScrollingEnabled}"
                                                 Margin="0,4,0,0"
                                                 ToolTip="Smooths wheel scrolling in lists and panes. Turn off for default native scrolling."/>
                            </GroupBox>
                        </WrapPanel>
                    </controls:Section>

                    <!-- Debug Section -->
                    <controls:Section Title="Debug"
                                      Margin="0,16,0,0">
                        <controls:Section.HeaderContent>
                            <Button Style="{DynamicResource IconButton}"
                                    controls:IconButtonProperties.IsActive="{Binding DebugModeEnabled}"
                                    Command="{s:Action ToggleDebugMode}"
                                    ToolTip="Enable or disable debug controls">
                                <Grid>
                                    <ui:SymbolIcon Symbol="LockClosed24"
                                                   FontSize="18"
                                                   Visibility="{Binding DebugModeEnabled, Converter={x:Static s:BoolToVisibilityConverter.InverseInstance}}"/>
                                    <ui:SymbolIcon Symbol="LockOpen24"
                                                   FontSize="18"
                                                   Visibility="{Binding DebugModeEnabled, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>
                                </Grid>
                            </Button>
                        </controls:Section.HeaderContent>

                        <Border Style="{StaticResource DebugSectionContentContainerStyle}">
                            <controls:SimpleStackPanel>
                                <controls:SimpleStackPanel Orientation="Horizontal"
                                                           Spacing="8">
                                    <Button Command="{s:Action ShowDebugMessageBoxSample}"
                                            Content="Sample MessageBox"/>
                                    <Button Command="{s:Action ShowDebugDialogSample}"
                                            Content="Sample DialogBox"/>
                                </controls:SimpleStackPanel>

                                <GroupBox Header="Crash Log Verbosity"
                                          Margin="0,8,0,0">
                                    <controls:SimpleStackPanel>
                                        <controls:Slider
                                            Minimum="0"
                                            Maximum="2"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            TickPlacement="BottomRight"
                                            Value="{Binding CrashLogVerbosity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            ThumbToolTipOptions="Errors|Warnings + Errors|All Steps"
                                            ThumbToolTipFallback="Verbosity: {0}"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="Errors"
                                                       FontSize="11"
                                                       HorizontalAlignment="Left"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="Warnings + Errors"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="All Steps"
                                                       FontSize="11"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </Grid>
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding CrashLogVerbosityDescription}"
                                                   TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </controls:SimpleStackPanel>
                                </GroupBox>

                                <ui:ToggleSwitch Content="Log played notes"
                                                 IsChecked="{Binding LogPlayedNotes}"
                                                 Margin="0,8,0,0"
                                                 ToolTip="Logs played note details (orig/transposed/key/velocity) and scheduler timing drift to input-output.log and scheduler.log."/>

                                <ui:ToggleSwitch Content="Enable page caching"
                                                 IsChecked="{Binding PageCaching}"
                                                 Margin="0,8,0,0"
                                                 ToolTip="When enabled, main navigation pages are cached in memory after first load to make navigation instantaneous. Turn off to force views to recreate every time."/>
                            </controls:SimpleStackPanel>
                        </Border>
                    </controls:Section>

                </controls:SimpleStackPanel>
            </Grid>

        </controls:SimpleStackPanel>
    </ScrollViewer>
</UserControl>
